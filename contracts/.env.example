# ─── SWYFTPAY Contracts — Environment ─────────────────────────────────────────
# Copy this to .env and fill in your values. NEVER commit .env to git.

# ─── Deployer Wallet ──────────────────────────────────────────────────────────
# The PRIVATE KEY of address 0x8cF19F899dd6d5f8a07F4CbD9B3412A6D10d7423
# Export from MetaMask: Account Details → Show Private Key
DEPLOYER_PRIVATE_KEY=your-private-key-here-without-0x-prefix

# ─── Network ─────────────────────────────────────────────────────────────────
# Public Polygon Amoy RPC (or use Alchemy/Infura for better reliability)
AMOY_RPC_URL=https://rpc-amoy.polygon.technology

# ─── Polygonscan (for contract verification) ──────────────────────────────────
# Get a free key at https://polygonscan.com/myapikey
POLYGONSCAN_API_KEY=your-polygonscan-api-key-here
