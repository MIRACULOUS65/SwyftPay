# ─── SwyftPay Backend Settlement Service ─────────────────────────────────────
# Copy this file to .env and fill in values. NEVER commit .env to git.

# Deployer wallet (owns the Router contract — can call settleOrder/cancelOrder)
DEPLOYER_PRIVATE_KEY=your-deployer-private-key-here

# Polygon Amoy RPC
AMOY_RPC_URL=https://rpc-amoy.polygon.technology

# Supabase PostgreSQL connection string
DATABASE_URL=postgresql://postgres.xxxxx:password@aws-x.pooler.supabase.com:6543/postgres

# Fixed INR per AMOY rate (update this when price changes)
INR_RATE_PER_AMOY=7500
